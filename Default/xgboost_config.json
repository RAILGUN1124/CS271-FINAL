{
  "objective": "binary:logistic",
  "booster": "gbtree",
  "n_estimators": 500,
  "learning_rate": 0.1,
  "max_depth": 0,
  "max_leaves": 64,
  "grow_policy": "lossguide",
  "subsample": 0.9,
  "colsample_bytree": 0.9,
  "colsample_bynode": 0.9,
  "min_child_weight": 0.001,
  "max_delta_step": 0,
  "reg_alpha": 0.0,
  "reg_lambda": 1.0,
  "eval_metric": ["auc", "logloss", "error"],
  "n_jobs": -1,
  "tree_method": "hist",
  "device": "cuda",
  "seed": 42,
  "verbosity": 1,
  "scale_pos_weight": 1.0
}